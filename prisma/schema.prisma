// 1. กำหนดตัวสร้าง Client เพื่อให้ Next.js เรียกใช้งานได้
generator client {
  provider = "prisma-client-js"
}

// 2. เชื่อมต่อกับ PostgreSQL ใน Docker โดยใช้ DATABASE_URL
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  bio           String?
  accounts      Account[]
  posts         Post[]
  comments      Comment[]
  pcBuilds      PCBuild[] 
  role          String    @default("USER")
  status        String    @default("ACTIVE") // "ACTIVE", "SUSPENDED", "BANNED"
  reportCount   Int       @default(0)
  reports       Report[]
  
  notifications Notification[]
  likedPosts    Post[]         @relation("UserPostLikes")
  likedComments Comment[]      @relation("UserCommentLikes")
}



model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  category  String
  status    String   @default("Public") 
  images    String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  authorId  String   // เปลี่ยนเป็น String ให้ตรงกับ User.id
  author    User     @relation(fields: [authorId], references: [id])
  
  comments  Comment[]
  
  pcBuildId String?
  pcBuild   PCBuild? @relation(fields: [pcBuildId], references: [id])
  
  likedBy   User[]   @relation("UserPostLikes")
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  
  authorId  String   // เปลี่ยนเป็น String ให้ตรงกับ User.id
  author    User     @relation(fields: [authorId], references: [id])
  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  likedBy   User[]   @relation("UserCommentLikes")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   // ฝั่งผู้รับ (เช่น Admin, User)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "REPORT", "SYSTEM", "WARNING" ฯลฯ
  message   String
  link      String?  // ลิงก์ตอนคลิก (Optional)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}


// ส่วนสำหรับระบบจัดสเปคคอมพิวเตอร์ (PC Builder)

model Component {
  id             String   @id @default(cuid())
  name           String
  type           String   // "CPU", "GPU", "RAM", "MB", "STORAGE", "PSU", "CASE"
  brand          String
  price          Float
  image          String?
  description    String?  @db.Text

  // -- Compatibility --
  socket         String?  // LGA1700, AM5
  ramType        String?  // DDR4, DDR5
  formFactor     String?  // ATX, ITX
  capacity       Int?     // GB สำหรับ RAM/Storage, Watt สำหรับ PSU

  // -- Physical Dimensions & Power (Compatibility System) --
  tdp            Int?     // การกินไฟ (Watt) สำหรับ CPU, GPU
  lengthMm       Int?     // ความยาวอุปกรณ์ (mm) สำหรับ GPU, Cooling
  maxGpuLength   Int?     // เฉพาะ CASE: ความยาว GPU สูงสุดที่รองรับ (mm)
  maxCoolerHeight Int?    // เฉพาะ CASE: ความสูง CPU Cooler สูงสุดที่รองรับ (mm)
  supportedMobo  String?  // เฉพาะ CASE: ไซส์บอร์ดที่รองรับ เช่น "ATX, Micro-ATX, Mini-ITX"
  psuFormFactor  String?  // เฉพาะ PSU: รูปแบบ เช่น "ATX", "SFX"
  coolingType    String?  // เฉพาะ COOLING: "Air Cooler" หรือ "Liquid Cooler"

  // -- Performance Scores (PassMark Based) --
  cpuSingleScore Int?     // Single Thread Rating
  cpuMultiScore  Int?     // Multi Thread Mark
  gpuScore       Int?     // G3D Mark
  
  // -- Additional Metrics for Weighting --
  vramGb         Int?     // สำหรับ GPU (3D Score)
  ramSpeed       Int?     // MHz (Gaming Score)
  readSpeed      Int?     // MB/s สำหรับ Storage
  writeSpeed     Int?     // MB/s สำหรับ Storage

  // -- Classification --
  chipset        String?  // AMD, NVIDIA, Intel, etc. (for GPU/CPU/Motherboard)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PCBuild {
  id            String   @id @default(cuid())
  name          String   // ชื่อเซ็ตคอม เช่น "เซ็ตเล่นเกมคุ้มๆ 2026"
  
  // ผูกกับ User ที่เป็นคนจัดสเปคนี้ (ลบ Cascade คือถ้า User ลบบัญชี สเปคนี้จะหายไปด้วย)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // -- เก็บ ID ของอุปกรณ์แต่ละชิ้นที่ผู้ใช้เลือก --
  cpuId         String?
  gpuId         String?
  ramId         String?
  motherboardId String?
  storageId     String?
  psuId         String?
  caseId        String?

  // สามารถใช้คำนวณราคารวม หรือเก็บคะแนนรวม (%) ไว้เลยเพื่อความเร็วในการโหลด
  totalPrice    Float    @default(0)
  
  gamingScore   Float?   // % Gaming
  workingScore  Float?   // % Working
  renderScore   Float?   // % 3D/Render


  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  posts         Post[]
}

// ----------------------------------------------------
// ระบบรายงานปัญหา (Report System)
// ----------------------------------------------------
model Report {
  id          String   @id @default(cuid())
  type        String   // "POST", "COMMENT", "USER", "PCBUILD"
  reason      String   // หมวดหมู่ เช่น "Spam", "Inappropriate", "Harassment"
  description String?  @db.Text
  severity    String   @default("LOW")     // "LOW", "MEDIUM", "HIGH", "URGENT"
  status      String   @default("PENDING") // "PENDING", "RESOLVED", "IGNORED"
  
  // ผู้รายงาน
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  
  // สิ่งที่ถูกรายงาน (เก็บเป็น ID ยืดหยุ่น หรืออาจจะโยง relation ชัดเจนถ้าต้องการ)
  targetId    String   
  targetUrl   String?  // ลิงก์ไปยังสิ่งที่ถูกรายงาน (Optional ประหยัดเวลา Query)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}



// ----------------------------------------------------
// ส่วนสำหรับสเปกแนะนำ (Preset Builds / Build Wizard)
// Admin สามารถสร้าง/แก้ไข Preset สเปกแนะนำสำเร็จรูป
// ที่จะแสดงใน Build Wizard เมื่อผู้ใช้ตอบคำถาม
// ----------------------------------------------------

model PresetBuild {
  id          String   @id @default(cuid())
  name        String   // ชื่อ Preset เช่น "สเปกเล่นเกม งบ 15,000"
  usage       String   // "GAMING" | "WORKING" | "CREATIVE"
  budget      String   // "ENTRY" | "MID" | "HIGHEND" | "ULTRA"
  description String?  @db.Text // คำอธิบายสั้นๆ ของ Preset นี้
  components  Json     // [{ type, name, reason, price }]
  totalPrice  Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}